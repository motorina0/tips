package lnbits:extension;

interface host {
  record storage-get-request {
    table: string,
    id: string
  }

  record storage-get-response {
    data-json: option<string>
  }

  record storage-set-request {
    table: string,
    data-json: string
  }

  record storage-set-response {
    ok: bool
  }

  record storage-paginated-request {
    table: string,
    filters-json: string,
    search: string,
    search-fields: list<string>,
    sort-by: string,
    descending: bool,
    limit: u32,
    offset: u32
  }

  record storage-paginated-response {
    rows-json: string,
    total: u64
  }

  record storage-delete-request {
    table: string,
    id: string
  }

  record storage-delete-response {
    ok: bool
  }

  record invoice-request {
    wallet-id: string,
    amount-sat: u64,
    currency: string,
    memo: string,
    tag: string,
    extra: list<tuple<string, string>>
  }

  record invoice-public-request {
    id: string,
    amount: f64,
    currency: string,
    memo: string
  }

  record invoice-response {
    payment-hash: string,
    payment-request: string,
    checking-id: string
  }

  record user-wallet-summary {
    id: string,
    name: string,
    currency: option<string>
  }

  record list-user-wallets-response {
    wallets: list<user-wallet-summary>
  }

  record random-id-request {
    prefix: string
  }

  record random-id-response {
    id: string
  }

  record now-response {
    timestamp: u64
  }

  record log-request {
    level: string,
    message: string
  }

  record log-response {
    ok: bool
  }

  storage-get: func(request: storage-get-request) -> storage-get-response;
  storage-get-public: func(request: storage-get-request) -> storage-get-response;
  storage-set: func(request: storage-set-request) -> storage-set-response;
  storage-get-paginated: func(request: storage-paginated-request) -> storage-paginated-response;
  storage-delete: func(request: storage-delete-request) -> storage-delete-response;
  create-invoice: func(request: invoice-request) -> invoice-response;
  create-invoice-public: func(request: invoice-public-request) -> invoice-response;
  list-user-wallets: func() -> list-user-wallets-response;
  random-id: func(request: random-id-request) -> random-id-response;
  now: func() -> now-response;
  log: func(request: log-request) -> log-response;
}

world tips {
  import host;

  export create-tip-jar: func(request-json: string) -> string;
  export list-tip-jars: func(request-json: string) -> string;
  export list-tip-jar-tips: func(request-json: string) -> string;
  export list-tip-wallets: func(request-json: string) -> string;
  export get-public-tip-jar: func(request-json: string) -> string;
  export create-tip-invoice: func(request-json: string) -> string;
  export record-payment: func(event-json: string) -> string;
}
