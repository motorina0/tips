{
  "version": 1,
  "description": "Track paid status and payment lookup metadata for tips.",
  "operations": [
    {
      "op": "add_field",
      "table": "tips",
      "field": "paid",
      "type": "boolean",
      "default": false
    },
    {
      "op": "add_field",
      "table": "tips",
      "field": "paid_at",
      "type": "datetime",
      "nullable": true
    },
    {
      "op": "create_index",
      "table": "tips",
      "name": "tips_by_payment_hash",
      "field": "payment_hash"
    }
  ]
}
