{
  "version": 1,
  "description": "Create the initial tips storage collections.",
  "operations": [
    {
      "op": "create_table",
      "table": "tip_jars",
      "fields": [
        {
          "name": "id",
          "type": "string"
        },
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        },
        {
          "name": "slug",
          "type": "string"
        },
        {
          "name": "suggested_amounts",
          "type": "number",
          "list": true
        },
        {
          "name": "thank_you_message",
          "type": "string"
        },
        {
          "name": "created_at",
          "type": "datetime"
        },
        {
          "name": "updated_at",
          "type": "datetime"
        }
      ]
    },
    {
      "op": "create_collection",
      "collection": "tips",
      "private_prefix": "private:tip:",
      "fields": [
        {
          "name": "id",
          "type": "string"
        },
        {
          "name": "jar_id",
          "type": "string"
        },
        {
          "name": "amount_sat",
          "type": "integer"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "message",
          "type": "string"
        },
        {
          "name": "payment_hash",
          "type": "string"
        },
        {
          "name": "created_at",
          "type": "datetime"
        }
    },
    {
      "op": "create_index",
      "collection": "tips",
      "name": "tips_by_jar",
      "prefix": "public:tip:",
      "field": "jar_id"
    }
  ]
}
